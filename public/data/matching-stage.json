{
  "stageKey": "matching",
  "version": 1,
  "screen": {
    "title": "ביומימיקרי – משחק התאמה",
    "subtitle": "מתחו קו בין כל אורגניזם לבין הטכנולוגיה שקיבלה ממנו השראה."
  },
  "preStagePopup": {
    "title": "לפני שמתחילים – כך תאספו את הקוד",
    "cards": [
      {
        "id": "code-explanation",
        "title": "איך אוספים את הקוד לפתיחת הדלת?",
        "body": [
          "בכל שלב במשחק תרוויחו חלק מהקוד.",
          "בסיום כל משימה מוצלחת תקבלו ספרה או ספרות שתצטרכו לשמור.",
          "רק אחרי שתעברו את כל השלבים ותחברו את כל הספרות לפי הסדר, תוכלו לפתוח את הדלת."
        ]
      },
      {
        "id": "matching-explanation",
        "title": "איך משחקים בשלב ההתאמה?",
        "body": [
          "מתחו קו בין כל אורגניזם לבין ההמצאה שקיבלה ממנו השראה.",
          "על כל התאמה נכונה בניסיון הראשון תקבלו 5 נקודות."
        ]
      }
    ],
    "buttonLabel": "הבנתי, אפשר להתחיל"
  },
  "rules": {
    "matchingDirection": "bidirectional",
    "attemptScoring": {
      "firstTry": 5,
      "secondTry": 2,
      "thirdTryOrMore": 0
    },
    "wrongMatch": {
      "showPopup": false,
      "lineBehavior": "flash-and-remove",
      "flashEffect": "subtle"
    },
    "correctMatch": {
      "showPopup": true,
      "lineBehavior": "lock-and-persist",
      "linePersistsUntilStageEnd": true,
      "incrementProgress": true
    },
    "imageZoom": {
      "enabled": true,
      "openOnClick": true,
      "closeOnOverlayClick": true,
      "size": "centered-medium"
    },
    "progress": {
      "start": "0/6",
      "end": "6/6",
      "totalPairs": 6
    },
    "finishFlow": {
      "afterSixthMatch": [
        "show-last-pair-popup",
        "close-last-pair-popup",
        "show-stage-completion-popup",
        "continue-to-next-stage-as-usual"
      ]
    }
  },
